APP_ENV=development
APP_NAME=URIM
ENGINE_NAME=Kairos
APP_VERSION=0.1.0
DEFAULT_LOCALE=fr-CD
DEFAULT_CURRENCY=CDF

DATABASE_URL=
REDIS_URL=
OBJECT_STORAGE_URL=

ENABLE_LIVE=false
ENABLE_REAL_BETTING=false
ALLOW_TEST_FIXTURES=false
ALLOW_PRODUCTION_MOCKS=false

# Phase 14 documents future provider secret names only as empty placeholders.
# Add real provider secrets later through a secret manager, never in Git.
PROVIDER_API_KEY=
PROVIDER_API_SECRET=
PROVIDER_WEBHOOK_SECRET=
PROVIDER_CLIENT_ID=
PROVIDER_CLIENT_SECRET=

# API integration scaffold: URIM mock/demo only; keep these commented until
# a backend provider passes human validation and onboarding gates.
