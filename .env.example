APP_ENV=development
APP_NAME=URIM
ENGINE_NAME=Kairos
APP_VERSION=0.1.0
DEFAULT_LOCALE=fr-CD
DEFAULT_CURRENCY=CDF

DATABASE_URL=
REDIS_URL=
OBJECT_STORAGE_URL=

ENABLE_LIVE=false
ENABLE_REAL_BETTING=false
ALLOW_TEST_FIXTURES=false
ALLOW_PRODUCTION_MOCKS=false

# Programme B1 — backend only. Keep the key empty in Git and set it only in
# Render's secret environment. The provider stays disabled without both the
# key and the explicit enable flag.
API_FOOTBALL_KEY=
API_FOOTBALL_ENABLED=false
API_FOOTBALL_PRIORITY_COMPETITIONS=
API_FOOTBALL_SEASON=
API_FOOTBALL_REQUEST_TIMEOUT_SECONDS=10
API_FOOTBALL_MAX_RETRIES=2
API_FOOTBALL_REQUESTS_PER_MINUTE=10
API_FOOTBALL_MAX_REQUESTS_PER_SYNC=10
API_FOOTBALL_UPCOMING_DAYS=7
API_FOOTBALL_FRESHNESS_MINUTES=180

# Exact public frontend origins only. Wildcards are rejected by the API.
CORS_ORIGINS=http://localhost:3000,https://urim.pro,https://www.urim.pro,https://urim-web.onrender.com

# Legacy provider placeholders remain empty and are not used by Programme B1.
PROVIDER_API_KEY=
PROVIDER_API_SECRET=
PROVIDER_WEBHOOK_SECRET=
PROVIDER_CLIENT_ID=
PROVIDER_CLIENT_SECRET=
